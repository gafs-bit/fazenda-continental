# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# From @BotFather on Telegram: message it, run /newbot, follow the prompts.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs allowed to query the bot.
# Leave empty at first: start the bot, message it from Telegram, and its
# reply will include your user id — copy it here and restart the bot.
ALLOWED_TELEGRAM_USER_IDS=

# Seconds to wait for `claude -p` to answer before giving up (optional, default 180)
CLAUDE_TIMEOUT_SECONDS=180
